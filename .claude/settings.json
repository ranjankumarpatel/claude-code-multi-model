{
  "model": "claude-opus-4-6",
  "enabledPlugins": {
    "codex@openai-codex": true
  },
  "permissions": {
    "allow": [
      "mcp__playwright"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/post-commit-readme.sh\"",
            "statusMessage": "Checking if README needs updating..."
          }
        ]
      }
    ]
  }
}
