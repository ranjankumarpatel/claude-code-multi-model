{
  "name": "multi-model",
  "version": "1.3.0",
  "description": "Portable multi-model orchestration: delegate to Ollama cloud, NVIDIA NIM, NVIDIA Security, Codex, GitHub Copilot CLI, and Google Gemini CLI from Claude Code.",
  "author": { "name": "ranjankumarpatel" },
  "mcpServers": {
    "ollama": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/mcp-ollama.mjs"],
      "env": {
        "OLLAMA_HOST": "${OLLAMA_HOST:-http://localhost:11434}",
        "MCP_GLOBAL_MODULES": "${MCP_GLOBAL_MODULES}"
      }
    },
    "nvidia-nim": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/mcp-nvidia.mjs"],
      "env": {
        "NVIDIA_API_KEY": "${NVIDIA_API_KEY}",
        "MCP_GLOBAL_MODULES": "${MCP_GLOBAL_MODULES}"
      }
    },
    "nvidia-security": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/mcp-security-nvidia.mjs"],
      "env": {
        "NVIDIA_API_KEY": "${NVIDIA_API_KEY}",
        "MCP_GLOBAL_MODULES": "${MCP_GLOBAL_MODULES}"
      }
    },
    "copilot": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/mcp-copilot.mjs"],
      "env": {
        "GH_TOKEN": "${GH_TOKEN}",
        "GITHUB_TOKEN": "${GITHUB_TOKEN}",
        "MCP_GLOBAL_MODULES": "${MCP_GLOBAL_MODULES}"
      }
    },
    "codex": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/mcp-codex.mjs"],
      "env": {
        "CODEX_HOME": "${CODEX_HOME}",
        "MCP_GLOBAL_MODULES": "${MCP_GLOBAL_MODULES}"
      }
    },
    "opencode": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/mcp-opencode.mjs"],
      "env": {
        "OPENCODE_SERVER_PASSWORD": "${OPENCODE_SERVER_PASSWORD}",
        "MCP_GLOBAL_MODULES": "${MCP_GLOBAL_MODULES}"
      }
    },
    "gemini": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/mcp-gemini.mjs"],
      "env": {
        "GEMINI_API_KEY": "${GEMINI_API_KEY}",
        "GOOGLE_API_KEY": "${GOOGLE_API_KEY}",
        "GOOGLE_APPLICATION_CREDENTIALS": "${GOOGLE_APPLICATION_CREDENTIALS}",
        "MCP_GLOBAL_MODULES": "${MCP_GLOBAL_MODULES}"
      }
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/opus-executor-guard.mjs"
          }
        ]
      }
    ]
  }
}
